{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build game",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/src/QuietValley.Game/QuietValley.Game.csproj"
      ],
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      "label": "test",
      "type": "process",
      "command": "dotnet",
      "args": [
        "test",
        "${workspaceFolder}/tests/QuietValley.SmokeTests/QuietValley.SmokeTests.csproj",
        "--collect:XPlat Code Coverage"
      ],
      "problemMatcher": "$msCompile",
      "group": "test"
    },
    {
      "label": "format check",
      "type": "process",
      "command": "dotnet",
      "args": [
        "csharpier",
        "check",
        "${workspaceFolder}"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "format",
      "type": "process",
      "command": "dotnet",
      "args": [
        "csharpier",
        "format",
        "${workspaceFolder}"
      ],
      "problemMatcher": []
    }
  ]
}
