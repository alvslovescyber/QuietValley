{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run QuietValley",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build game",
      "program": "${workspaceFolder}/src/QuietValley.Game/bin/Debug/net9.0/QuietValley.Game.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/QuietValley.Game/bin/Debug/net9.0",
      "console": "internalConsole",
      "stopAtEntry": false
    },
    {
      "name": "Run xUnit Tests",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "test",
      "program": "dotnet",
      "args": [
        "test",
        "${workspaceFolder}/tests/QuietValley.SmokeTests/QuietValley.SmokeTests.csproj"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    }
  ]
}
